#include <stdio.h>

int main() {
    int n, i;
    float sum = 0.0;

    
    printf("Enter the value of n (limit): ");
    scanf("%d", &n);


    for (i = 1; i <= n; i++) {

        sum += 1.0 / i;
        
        if (i == 1)
            printf("1");
        else
            printf(" + 1/%d", i);
    }

    printf("\n\nSum of the series is: %.4f\n", sum);

    return 0;
}